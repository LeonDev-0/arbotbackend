
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Usuarios del sistema ────────────────────────────────────────────────────
model Usuario {
  id          Int       @id @default(autoincrement())
  username    String    @unique
  password    String    // bcrypt hash
  rol         String    @default("cliente")  // "admin" | "cliente"
  activo      Boolean   @default(true)
  // Expiración de la cuenta (null = sin límite, solo admin tiene null)
  expiraEn    DateTime?
  creadoEn    DateTime  @default(now())

  // Relaciones propias de cada cliente
  dispositivos      Dispositivo[]
  servicios         Servicio[]
  cuentasCliente    CuentaCliente[]
  demos             CuentaDemo[]
  clientesDemo      ClienteDemo[]
  plantillasMsg     PlantillaRecordatorio[]
}

// ─── Servicios (por usuario) ─────────────────────────────────────────────────
model Servicio {
  id         Int    @id @default(autoincrement())
  usuarioId  Int
  nombre     String
  color      String @default("#22c55e")
  demosActivo      Boolean @default(true)
  msgDemoEntregada String?
  msgDemoYaTiene   String?
  msgDemoSinStock  String?
  msgDemoDesactivado String?

  usuario        Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  dispositivos   Dispositivo[]
  cuentasCliente CuentaCliente[]
  demos          CuentaDemo[]
  clientesDemo   ClienteDemo[]

  @@unique([usuarioId, nombre])
}

// ─── Dispositivos WhatsApp (máx 2 por usuario) ───────────────────────────────
model Dispositivo {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  nombre     String
  servicioId Int?
  pais       String?
  // "desconectado" | "pausado" | "esperando_qr" | "conectado"
  estado     String   @default("desconectado")
  telefono   String?
  creadoEn   DateTime @default(now())

  usuario  Usuario          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  servicio Servicio?        @relation(fields: [servicioId], references: [id])
  reglas   RespuestaRegla[]
}

// ─── Reglas y pasos de respuesta automática (por dispositivo) ────────────────
model RespuestaRegla {
  id            Int      @id @default(autoincrement())
  dispositivoId Int
  palabrasClave String
  orden         Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now())

  dispositivo Dispositivo     @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)
  pasos       RespuestaPaso[]
}

model RespuestaPaso {
  id        Int     @id @default(autoincrement())
  reglaId   Int
  orden     Int     @default(0)
  tipo      String  @default("texto")   // "texto" | "imagen" | "video"
  contenido String
  caption   String?
  delayMs   Int     @default(0)

  regla RespuestaRegla @relation(fields: [reglaId], references: [id], onDelete: Cascade)
}

// ─── Plantillas de recordatorio (por usuario) ────────────────────────────────
model PlantillaRecordatorio {
  id        Int    @id @default(autoincrement())
  usuarioId Int
  nombre    String // "Cuenta expirada", "Próximo vencimiento", etc.
  // "texto" | "imagen"
  tipo      String @default("texto")
  mensaje   String // texto con variables {usuario} {servicio} {pais}
  imagenUrl String? // URL de imagen opcional
  creadoEn  DateTime @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
}

// ─── Cuentas de clientes (estructura plana, 1 registro = 1 cuenta) ───────────
model CuentaCliente {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  telefono   String
  usuario    String
  contrasena String
  servicioId Int
  pais       String   @default("Bolivia")
  notas      String?
  creadoEn   DateTime @default(now())

  usuarioRel Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  servicio   Servicio @relation(fields: [servicioId], references: [id])
}

// ─── Cuentas demo por servicio ───────────────────────────────────────────────
model CuentaDemo {
  id         Int      @id @default(autoincrement())
  usuarioId  Int
  servicioId Int
  usuario    String
  contrasena String
  disponible Boolean  @default(true)
  creadoEn   DateTime @default(now())

  usuarioRel Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  servicio   Servicio     @relation(fields: [servicioId], references: [id])
  sesiones   ClienteDemo[]
}

// ─── Clientes que pidieron demo (registro automático del bot) ────────────────
model ClienteDemo {
  id          Int      @id @default(autoincrement())
  usuarioId   Int
  telefono    String
  nombre      String
  cuentaId    Int
  servicioId  Int
  entregadoEn DateTime @default(now())

  usuarioRel Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cuenta     CuentaDemo @relation(fields: [cuentaId], references: [id])
  servicio   Servicio   @relation(fields: [servicioId], references: [id])

  @@unique([usuarioId, telefono, servicioId])
}
